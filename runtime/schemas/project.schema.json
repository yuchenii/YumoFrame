{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yumoframe.dev/schemas/project.schema.json",
  "description": "Resolved comedy-text render contract. Layout fields may be zero placeholders for runtime auto-layout.",
  "type": "object",
  "required": ["version", "template", "composition", "source", "theme", "timeline"],
  "properties": {
    "version": {"const": "0.1.0"},
    "template": {"const": "comedy-text"},
    "endOverview": {"type": "boolean"},
    "composition": {"type": "object"},
    "source": {"type": "object"},
    "theme": {"type": "object"},
    "audio": {"type": "object"},
    "timeline": {"type": "object"}
  },
  "additionalProperties": false
}

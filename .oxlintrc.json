{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-control-regex": "off"
  },
  "ignorePatterns": ["**/adapter-dist/**", "**/dist/**", "**/*.d.ts"],
  "env": {
    "builtin": true
  }
}

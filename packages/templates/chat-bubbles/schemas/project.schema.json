{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Chat Bubbles Project",
  "type": "object",
  "required": [
    "version",
    "template",
    "composition",
    "layout",
    "participants",
    "messages",
    "scrollStates"
  ],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "template": { "const": "chat-bubbles" },
    "composition": { "type": "object" },
    "layout": { "type": "object" },
    "participants": { "type": "array", "minItems": 1 },
    "messages": { "type": "array", "minItems": 1 },
    "scrollStates": { "type": "array" },
    "audio": { "type": "object" }
  }
}

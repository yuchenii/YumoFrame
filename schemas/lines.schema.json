{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yumoframe.dev/schemas/lines.schema.json",
  "type": "object",
  "required": ["version", "template", "lines"],
  "properties": {
    "version": { "const": "0.1.0" },
    "template": { "const": "rotating-flow" },
    "lines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["segments"],
        "properties": {
          "start": { "type": "number", "minimum": 0 },
          "end": { "type": "number", "exclusiveMinimum": 0 },
          "segments": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["text", "highlight"],
              "properties": {
                "text": { "type": "string", "minLength": 1 },
                "highlight": { "type": "boolean" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

{
  "name": "yumoframe",
  "version": "0.1.3",
  "description": "Remotion-based CLI for agent-authored kinetic vertical videos from text or media",
  "keywords": [
    "agent",
    "chinese",
    "cli",
    "kinetic-typography",
    "remotion",
    "skills",
    "video"
  ],
  "homepage": "https://github.com/yuchenii/YumoFrame#readme",
  "bugs": {
    "url": "https://github.com/yuchenii/YumoFrame/issues"
  },
  "author": "yuchenii",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yuchenii/YumoFrame.git"
  },
  "bin": {
    "yumoframe": "packages/cli/dist/cli.js"
  },
  "files": [
    "packages/cli/dist",
    "packages/templates",
    "processors",
    "skills",
    "schemas",
    "README.md",
    "README.en.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:adapters": "node scripts/build-template-adapters.mjs",
    "build:cli": "pnpm build:adapters && node -e \"require('node:fs').rmSync('packages/cli/dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "prepack": "pnpm build:cli",
    "test": "pnpm build:cli && node --test tests/*.test.mjs",
    "test:pack": "node scripts/run-packed-smoke.mjs --skip-render",
    "studio": "pnpm build:cli && node packages/cli/dist/cli.js studio",
    "render": "pnpm build:cli && node packages/cli/dist/cli.js render",
    "validate": "pnpm build:cli && node packages/cli/dist/cli.js validate",
    "resolve": "pnpm build:cli && node packages/cli/dist/cli.js resolve",
    "sync": "pnpm build:cli && node packages/cli/dist/cli.js sync",
    "layout": "pnpm build:cli && node packages/cli/dist/cli.js layout",
    "dev": "pnpm build:cli && node packages/cli/dist/cli.js dev",
    "typecheck": "pnpm build:adapters && tsc -p tsconfig.json --noEmit && tsc -p tsconfig.adapters.json && pnpm --filter './packages/templates/*' typecheck",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "build": "pnpm build:cli && pnpm --filter './packages/templates/*' build",
    "release": "release-it",
    "release:runtime": "release-it --hooks.after:bump=\"node scripts/sync-version.mjs --runtime\""
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.8",
    "@remotion/cli": "4.0.332",
    "@remotion/player": "4.0.332",
    "@remotion/renderer": "4.0.332",
    "commander": "^14.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remotion": "4.0.332"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "release-it": "^20.2.1",
    "typescript": "6.0.2",
    "vite": "8.0.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.7.0"
}

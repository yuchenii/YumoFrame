  "profiles": [
    {
      "id": "qwen3-custom-voice",
      "compatibleRunners": ["uv"],
      "match": { "runner": "uv", "name": "qwen3-tts", "modelSuffix": "-CustomVoice" },
      "execution": "native-batch",
      "controls": ["qwen-instruct"],
      "requiredConfig": ["options.speaker"],
      "controlOptions": {
        "qwen-instruct": {
          "required": ["instruct"],
          "constraints": { "instruct": "non-empty natural-language delivery instruction" },
          "example": { "type": "qwen-instruct", "instruct": "用轻松、略带调侃的语气说，语速稍快" }
        }
      },
      "timing": "align"
    },
    {
      "id": "qwen3-voice-design",
      "compatibleRunners": ["uv"],
      "match": { "runner": "uv", "name": "qwen3-tts", "modelSuffix": "-VoiceDesign" },
      "execution": "native-batch",
      "controls": ["qwen-voice-design"],
      "requiredWholeTextConfig": ["options.instruct"],
      "requiredPlan": ["voice.description"],
      "controlOptions": {
        "qwen-voice-design": {
          "required": ["instruct"],
          "constraints": {
            "instruct": "non-empty per-segment delivery instruction; the worker prepends stable voice.description"
          },
          "example": { "type": "qwen-voice-design", "instruct": "先克制地陈述，结尾带一点惊讶" }
        }
      },
      "timing": "align"
    },
    {
      "id": "qwen3-base",
      "compatibleRunners": ["uv"],
      "match": { "runner": "uv", "name": "qwen3-tts", "modelSuffix": "-Base" },
      "execution": "native-batch",
      "controls": ["none"],
      "requiredConfig": ["options.refAudio"],
      "configPaths": ["options.refAudio"],
      "controlOptions": {
        "none": {
          "required": [],
          "constraints": {
            "intent": "must be neutral because Base exposes no per-segment delivery instruction"
          },
          "example": { "type": "none" }
        }
      },
      "timing": "align"
    },
    {
      "id": "indextts2",
      "compatibleRunners": ["uv"],
      "match": { "runner": "uv", "name": "indextts2" },
      "execution": "persistent-loop",
      "controls": ["indextts2-emo-text", "indextts2-emo-vector", "indextts2-emo-audio"],
      "controlOptions": {
        "indextts2-emo-text": {
          "required": ["emoText", "emoAlpha"],
          "constraints": { "emoAlpha": { "minimum": 0, "maximum": 1 } },
          "example": {
            "type": "indextts2-emo-text",
            "emoText": "开心又带一点惊讶",
            "emoAlpha": 0.7
          }
        },
        "indextts2-emo-vector": {
          "required": ["emoVector"],
          "constraints": { "emoVector": { "length": 8, "itemMinimum": 0, "itemMaximum": 0.8 } },
          "example": { "type": "indextts2-emo-vector", "emoVector": [0.1, 0.6, 0, 0, 0, 0, 0, 0] }
        },
        "indextts2-emo-audio": {
          "required": ["emoAudio", "emoAlpha"],
          "constraints": {
            "emoAudio": "non-empty audio path",
            "emoAlpha": { "minimum": 0, "maximum": 1 }
          },
          "example": {
            "type": "indextts2-emo-audio",
            "emoAudio": "references/happy.wav",
            "emoAlpha": 0.8
          }
        }
      },
      "timing": "align"
    },
    {
      "id": "edge-tts",
      "compatibleRunners": ["command"],
      "execution": "sequential",
      "controls": ["edge-prosody"],
      "controlOptions": {
        "edge-prosody": {
          "required": ["rate", "pitch", "volume"],
          "constraints": {
            "rate": "signed percent, for example +10%",
            "pitch": "signed hertz, for example -5Hz",
            "volume": "signed percent, for example +0%"
          },
          "example": { "type": "edge-prosody", "rate": "+10%", "pitch": "+0Hz", "volume": "+0%" }
        }
      },
      "timing": "align"
    },
    {
      "id": "dashscope-qwen3-tts-instruct-flash",
      "compatibleRunners": ["api"],
      "match": {
        "runner": "api",
        "provider": "dashscope",
        "modelSuffix": "qwen3-tts-instruct-flash"
      },
      "execution": "sequential",
      "controls": ["dashscope-instruct"],
      "requiredConfig": ["voice", "apiKeyEnv"],
      "controlOptions": {
        "dashscope-instruct": {
          "required": ["instructions"],
          "constraints": {
            "instructions": "non-empty Chinese or English delivery instruction, at most 1600 tokens"
          },
          "example": {
            "type": "dashscope-instruct",
            "instructions": "语速稍快，语调明显上扬，适合介绍时尚产品"
          }
        }
      },
      "timing": "align"
    },
    {
      "id": "dashscope-qwen3-tts-flash",
      "compatibleRunners": ["api"],
      "match": {
        "runner": "api",
        "provider": "dashscope",
        "modelSuffix": "qwen3-tts-flash"
      },
      "execution": "single",
      "controls": ["none"],
      "requiredConfig": ["voice", "apiKeyEnv"],
      "controlOptions": {
        "none": {
          "required": [],
          "constraints": {
            "intent": "must be neutral because qwen3-tts-flash has no instruction control"
          },
          "example": { "type": "none" }
        }
      },
      "timing": "align"
    },
    {
      "id": "openai-gpt-4o-mini-tts",
      "compatibleRunners": ["api"],
      "match": { "runner": "api", "provider": "openai", "modelSuffix": "gpt-4o-mini-tts" },
      "execution": "sequential",
      "controls": ["openai-speech"],
      "requiredConfig": ["voice"],
      "controlOptions": {
        "openai-speech": {
          "required": ["instructions", "speed"],
          "constraints": {
            "instructions": "non-empty natural-language delivery instruction",
            "speed": { "minimum": 0.25, "maximum": 4 }
          },
          "example": {
            "type": "openai-speech",
            "instructions": "Speak warmly, then end with mild surprise.",
            "speed": 1.05
          }
        }
      },
      "timing": "align"
    }
  ]
}

# package.json "files" already limits the tarball to published source groups.
# These patterns strip development artifacts from those directories.

packages/**/node_modules/**
packages/**/.remotion/**
packages/**/__pycache__/**
packages/**/*.pyc
packages/**/.pytest_cache/**
packages/**/*.tsbuildinfo
processors/**/.venv/**
processors/**/__pycache__/**
processors/**/*.pyc
processors/**/.pytest_cache/**

packages/templates/**/out/**
packages/templates/**/dist/**
packages/templates/**/coverage/**

# Processor unit tests are for the repo, not the installed CLI.
processors/**/tests/**

**/.DS_Store
*.log
